@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-dark text-white text-center">
                    <h4 class="mb-0">🏠 Hostel Management Login</h4>
                </div>
                <div class="card-body p-4">

                    @* Bước 1: Chọn Role *@
                    <p class="text-center text-muted mb-3">
                        <strong>Select your role to login</strong>
                    </p>

                    <div class="d-flex justify-content-center gap-2 mb-4">
                        <a asp-action="Login" asp-route-role="Tenant"
                           class="btn @(Model.Role == "Tenant" ? "btn-primary" : "btn-outline-primary")">
                            👤 Tenant
                        </a>
                        <a asp-action="Login" asp-route-role="HostelOwner"
                           class="btn @(Model.Role == "HostelOwner" ? "btn-success" : "btn-outline-success")">
                            🏡 Hostel Owner
                        </a>
                        <a asp-action="Login" asp-route-role="Admin"
                           class="btn @(Model.Role == "Admin" ? "btn-danger" : "btn-outline-danger")">
                            🛡️ Admin
                        </a>
                    </div>

                    <hr />

                    @* Bước 2: Form đăng nhập *@
                    <p class="text-center mb-3">
                        Login as
                        <strong class="
                            @(Model.Role == "Tenant"      ? "text-primary"  :
                              Model.Role == "HostelOwner" ? "text-success"  :
                                                            "text-danger")">
                            @Model.Role
                        </strong>
                    </p>

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Role" />

                        <div asp-validation-summary="All" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit"
                                    class="btn @(Model.Role == "Tenant"      ? "btn-primary"  :
                                                 Model.Role == "HostelOwner" ? "btn-success"  :
                                                                               "btn-danger")">
                                Login as @Model.Role
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
